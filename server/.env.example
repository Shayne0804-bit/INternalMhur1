NODE_ENV=development
PORT=3000

# Use MongoDB Atlas or another reachable MongoDB URI for Railway.
# MongoDB Compass is only a client UI; Railway cannot connect to your local Compass database.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rugir_auth?retryWrites=true&w=majority

# Generate long random values for production.
JWT_SECRET=replace-with-a-long-random-jwt-secret
LICENSE_KEY_PEPPER=replace-with-a-long-random-license-pepper
ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Short token lifetime for the DLL session.
TOKEN_TTL=15m

# Optional comma-separated browser origins. Leave empty for DLL-only usage.
ALLOWED_ORIGINS=

# Discord bot (runs in the same process as the server). Leave empty to disable.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional guild id for instant slash-command registration (single server). Empty = global.
DISCORD_GUILD_ID=
